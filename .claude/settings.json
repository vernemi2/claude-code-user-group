{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:soql.beyondthecloud.dev)",
      "WebFetch(domain:dml.beyondthecloud.dev)",
      "Bash(gh api:*)",
      "Bash(npm run:*)",
      "Bash(sf project:*)",
      "Bash(sf apex:*)",
      "mcp__plugin_playwright_playwright__browser_navigate",
      "mcp__plugin_playwright_playwright__browser_wait_for",
      "mcp__plugin_playwright_playwright__browser_click",
      "mcp__plugin_playwright_playwright__browser_take_screenshot"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/apex-guard.sh",
            "timeout": 30,
            "statusMessage": "Checking Apex best practices..."
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lwc-lint.sh",
            "timeout": 30,
            "statusMessage": "Running ESLint on LWC..."
          }
        ]
      }
    ]
  }
}
